*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
wheelhouse/

# JavaScript / frontend dependencies and generated assets
node_modules/
**/node_modules/
**/.vite/
**/coverage/
**/dist/

# Virtual environments and local package caches
.venv/
.venv-server/
venv/
env/
ENV/
.conda-env/
.pip-cache/
.cache/

# Test, lint, type-check and coverage caches
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.pyre/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Jupyter / notebook checkpoints
